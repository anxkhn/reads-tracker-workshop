<h1>Edit Author</h1>

<%= form_with model: @author, local: true do |f| %>
  <% if @author.errors.any? %>
    <div class="errors">
      <% @author.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div class="field">
    <%= f.label :name %>
    <%= f.text_field :name %>
  </div>

  <div class="field">
    <%= f.label :bio %>
    <%= f.text_area :bio, rows: 5 %>
  </div>

  <%= f.submit "Update Author", class: "btn btn-primary" %>
<% end %>

<%= link_to "Back to Author", @author %>