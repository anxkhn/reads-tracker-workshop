<div class="page-header">
  <h1>My Shelves</h1>
</div>

<div class="new-shelf-form">
  <h2>Create New Shelf</h2>
  <%= form_with model: @shelf, local: true do |f| %>
    <% if @shelf.errors.any? %>
      <div class="errors">
        <% @shelf.errors.full_messages.each do |msg| %>
          <p><%= msg %></p>
        <% end %>
      </div>
    <% end %>

    <div class="field">
      <%= f.text_field :name, placeholder: "Shelf name (e.g., Favorites, To Read)" %>
      <%= f.submit "Create Shelf", class: "btn btn-primary" %>
    </div>
  <% end %>
</div>

<div class="shelves-list">
  <% @shelves.each do |shelf| %>
    <div class="shelf-card">
      <h2><%= link_to shelf.name, shelf %></h2>
      <p class="book-count"><%= pluralize(shelf.books.count, 'book') %></p>
      <div class="shelf-actions">
        <%= link_to "View", shelf, class: "btn" %>
        <%= button_to "Delete", shelf, method: :delete, class: "btn btn-danger", data: { confirm: "Are you sure?" } %>
      </div>
    </div>
  <% end %>
</div>