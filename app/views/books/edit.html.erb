<h1>Edit Book</h1>

<%= form_with model: @book, local: true do |f| %>
  <% if @book.errors.any? %>
    <div class="errors">
      <% @book.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div class="field">
    <%= f.label :title %>
    <%= f.text_field :title %>
  </div>

  <div class="field">
    <%= f.label :author_id, "Author" %>
    <%= f.collection_select :author_id, @authors, :id, :name %>
  </div>

  <div class="field">
    <%= f.label :isbn %>
    <%= f.text_field :isbn %>
  </div>

  <div class="field">
    <%= f.label :description %>
    <%= f.text_area :description, rows: 5 %>
  </div>

  <div class="field">
    <%= f.label :cover_url, "Cover Image URL" %>
    <%= f.text_field :cover_url %>
  </div>

  <div class="field">
    <%= f.label :status %>
    <%= f.select :status, Book.statuses.keys.map { |s| [s.humanize, s] } %>
  </div>

  <%= f.submit "Update Book", class: "btn btn-primary" %>
<% end %>

<%= link_to "Back to Book", @book %>